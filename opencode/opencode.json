{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "Conduit": {
      "options": {
        "temperature": 0,
        "top_p": 1,
        "n": 1
      },
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    },
  },
  "provider": {
    "ollama": {
      "options": {
        "npm": "@ai-sdk/openai-compatible",
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.1:latest": {
          "name": "Llama 3.1"
        }
      }
    },
    "lmstudio": {
      "options": {
        "npm": "@ai-sdk/openai-compatible",
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "local": {
          "name": "LM Studio Local"
        }
      }
    }
  }
}

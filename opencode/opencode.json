{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "Conduit": {
      "options": {
        "temperature": 0,
        "top_p": 1,
        "n": 1
      }
    },
    "Support": {
      "options": {
        "temperature": 0.3,
        "top_p": 1,
        "n": 1
      }
    },
    "build": {
      "disable": true
    },
    "plan": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  },
  "provider": {
    "ollama": {
      "options": {
        "npm": "@ai-sdk/openai-compatible",
        "baseURL": "http://localhost:11434/v1"
      },
      "models": {
        "llama3.1:latest": {
          "name": "Llama 3.1"
        }
      }
    },
    "lmstudio": {
      "options": {
        "npm": "@ai-sdk/openai-compatible",
        "baseURL": "http://localhost:1234/v1"
      },
      "models": {
        "qwen3-14b": {
          "name": "Qwen3 14B"
        },
        "gemma-4-e4b": {
          "name": "Gemma 4 E4B"
        },
        "llama-3-8b-instruct-1048k": {
          "name": "Llama 3 8B Instruct 1048k"
        }
      }
    }
  }
}
